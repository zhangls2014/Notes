<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
  <style name="Theme.Notes" parent="Theme.Material3.Light.NoActionBar" />

  <style name="Theme.App.Starting" parent="Theme.SplashScreen">
    <item name="windowSplashScreenBackground">@android:attr/colorBackground</item>
    <item name="windowSplashScreenAnimatedIcon">@mipmap/app_ic_launcher</item>
    <item name="windowSplashScreenAnimationDuration">200</item>
    <item name="postSplashScreenTheme">@style/Theme.Notes</item>
    <item name="android:windowSplashScreenBehavior" tools:ignore="NewApi">icon_preferred</item>
  </style>
</resources>